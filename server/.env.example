# --- Terminus core ---
PORT=3300
# Shared secret. The Android app sends this in its Cloud Sync "API key" field.
# Leave empty for localhost/Termux-only use; REQUIRED before exposing to the internet.
TERMINUS_API_KEY=

# Where local state snapshots are written before Drive archiving.
DATA_DIR=./data

# --- Brain chain ---
# Tier 1: local Ollama (phi3). On the phone this is the Termux daemon.
OLLAMA_URL=http://127.0.0.1:11434
# Tier 2: Claude backup. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5
# Tier 3: Gemini last resort. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Google Drive archive (the 5TB Google One on a.i.intergrated.services@gmail.com) ---
# 1. Create an OAuth client (Desktop app) at https://console.cloud.google.com/apis/credentials
#    and enable the Google Drive API for the project.
# 2. Run `npm run auth` and sign in AS a.i.intergrated.services@gmail.com.
# 3. Paste the printed refresh token below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Root folder name created in that Drive:
DRIVE_ROOT_FOLDER=Kortana
