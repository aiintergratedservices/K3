# GEMINI_API_KEY: Last-resort cloud core (tier 3 of Kortana's brain).
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# ANTHROPIC_API_KEY: Claude API backup core (tier 2 of Kortana's brain).
# Used when local Ollama phi3 can't do what's needed. Placeholder value —
# set the real sk-ant-... key in your local .env (never commit it).
ANTHROPIC_API_KEY=MY_ANTHROPIC_API_KEY
